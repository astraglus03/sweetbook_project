# 실행 환경
NODE_ENV=development
PORT=3000

# CORS
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=sweetbook_user
DB_PASSWORD=sweetbook_pass
DB_NAME=sweetbook

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=replace_with_random_32_chars_minimum
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/oauth/google/callback

# OAuth - Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=http://localhost:3000/auth/oauth/kakao/callback

# OAuth redirect
OAUTH_SUCCESS_REDIRECT=http://localhost:5173/groups
OAUTH_FAILURE_REDIRECT=http://localhost:5173/login?error=oauth_failed

# Sweetbook API
SWEETBOOK_API_KEY=SB_prefix.SB_secret
SWEETBOOK_ENV=sandbox
SWEETBOOK_BASE_URL=https://api-sandbox.sweetbook.com/v1
SWEETBOOK_WEBHOOK_SECRET=replace_with_webhook_secret

# SMTP (이메일 발송 — 미설정 시 콘솔 로그로 대체)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GroupBook <noreply@groupbook.kr>

# OpenAI
OPENAI_API_KEY=

# Supabase Storage (이미지 업로드 — 모든 사진/커버/아바타)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=uploads
