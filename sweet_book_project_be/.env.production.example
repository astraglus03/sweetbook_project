# ===== Railway 프로덕션 환경변수 예시 =====
# Railway 대시보드 > Variables에서 설정. 아래는 복붙용 템플릿입니다.

NODE_ENV=production
PORT=3000

# CORS — Vercel 배포 URL
CORS_ORIGIN=https://<your-fe>.vercel.app

# PostgreSQL — Railway Postgres 플러그인 변수 (개별 필드 사용)
#   Railway가 자동 주입하는 PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE를 매핑
DB_HOST=${{Postgres.PGHOST}}
DB_PORT=${{Postgres.PGPORT}}
DB_USER=${{Postgres.PGUSER}}
DB_PASSWORD=${{Postgres.PGPASSWORD}}
DB_NAME=${{Postgres.PGDATABASE}}

# Redis — Railway Redis 플러그인
REDIS_HOST=${{Redis.REDISHOST}}
REDIS_PORT=${{Redis.REDISPORT}}
REDIS_PASSWORD=${{Redis.REDISPASSWORD}}

# JWT (32자 이상 — openssl rand -base64 48 로 새로 생성)
JWT_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# OAuth — Google / Kakao 콘솔에서 프로덕션 callback URL 화이트리스트 추가 필수
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://<your-be>.up.railway.app/auth/oauth/google/callback

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=https://<your-be>.up.railway.app/auth/oauth/kakao/callback

OAUTH_SUCCESS_REDIRECT=https://<your-fe>.vercel.app/groups
OAUTH_FAILURE_REDIRECT=https://<your-fe>.vercel.app/login?error=oauth_failed

# Sweetbook — 배포 후 PUT /webhooks/config 로 수신 URL 재등록 → secretKey 갱신
SWEETBOOK_API_KEY=
SWEETBOOK_ENV=sandbox
SWEETBOOK_BASE_URL=https://api-sandbox.sweetbook.com/v1
SWEETBOOK_WEBHOOK_SECRET=

# SMTP (선택)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GroupBook <noreply@groupbook.kr>

# Base URL — 이메일 링크/사진 URL 생성용 (BE 자기 자신 주소)
BASE_URL=https://<your-be>.up.railway.app

# OpenAI
OPENAI_API_KEY=
